# Standard C++23 configuration
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Display color in the terminal
common --color=yes

# Better error messages
build --verbose_failures
build --sandbox_debug

# Optimization
build --copt=-O3
build --copt=-march=native
build --copt=-ffast-math

# ThreadSanitizer (use: bazel test --config=tsan ...)
build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread
build:tsan --copt=-g
build:tsan --copt=-O1
build:tsan --copt=-fno-omit-frame-pointer

# Support for Python
# build --python_path=python3
